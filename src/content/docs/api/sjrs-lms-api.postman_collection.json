{
  "info": {
    "name": "SJRS LMS API - Complete Collection",
    "description": "API collection for SJRS Library Management System (cookie auth + CSRF via XSRF-TOKEN / X-XSRF-TOKEN). Includes authentication, superuser, and core feature endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "sjrs-lms",
    "version": "2.0.0"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.request.headers.remove('Authorization');",
          "const origin = pm.environment.get('origin') || pm.environment.get('base_url');",
          "if (origin) {",
          "  pm.request.headers.upsert({ key: 'Origin', value: origin });",
          "}",
          "const xsrf = pm.cookies.get('XSRF-TOKEN');",
          "if (xsrf) {",
          "  pm.request.headers.upsert({ key: 'X-XSRF-TOKEN', value: xsrf });",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "🔑 Authentication",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const jsonData = pm.response.json();",
                  "    const userId = jsonData.data?.user?.id || jsonData.user?.id;",
                  "    if (userId) {",
                  "        pm.environment.set(\"user_id\", userId.toString());",
                  "    }",
                  "    console.log(\"✓ Login success (auth cookie set)\");",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {"raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api", "auth", "login"]}
          }
        },
        {
